# ============================================================
# Hermes Agent profile — Environment Variables
# Upstream: https://github.com/NousResearch/hermes-agent
# Runtime: Python 3.11 + uv.
# ============================================================
TIMEZONE=America/Sao_Paulo
SWAP_SIZE_GB=2

# true  = run the upstream curl|bash installer (recommended).
# false = git clone + uv venv build (dev path).
HERMES_USE_UPSTREAM_INSTALLER=true

# Dev path knobs (only used if HERMES_USE_UPSTREAM_INSTALLER=false)
HERMES_DIR=/home/ubuntu/hermes-agent
HERMES_REPO=https://github.com/NousResearch/hermes-agent.git
HERMES_BRANCH=main

# --- Provider keys (set the ones you'll use; `hermes setup` will pick them up) ---
OPENROUTER_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
ELEVENLABS_API_KEY=
TELEGRAM_BOT_TOKEN=

# ============================================================
# Base tooling + DB clients (lib/base-packages.sh)
# ============================================================
BASE_PACKAGES=
INSTALL_DB_CLIENTS=true
INSTALL_POSTGRES_CLIENT=true
INSTALL_CLICKHOUSE_CLIENT=true
