# ============================================================
# OpenClaw profile — Environment Variables
# Upstream: https://github.com/openclaw/openclaw
# Installed via: npm install -g openclaw@<version>
# ============================================================
TIMEZONE=America/Sao_Paulo
SWAP_SIZE_GB=2

# Node major version (OpenClaw needs >= 22.19; 24 recommended).
NODE_MAJOR=22
PNPM_VERSION=latest

# npm version pin for openclaw itself.
OPENCLAW_VERSION=latest
# Default model written into ~/.openclaw/openclaw.json on first install.
OPENCLAW_MODEL=anthropic/claude-sonnet-4-6
# Gateway port (default 18789).
OPENCLAW_PORT=18789

# Run gateway as a systemd daemon. If true, runs `openclaw onboard --install-daemon`.
OPENCLAW_AS_SERVICE=false

# --- Provider keys (fill the ones your model + channels need) ---
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# --- Channel credentials (optional, only if you wire them up) ---
TELEGRAM_BOT_TOKEN=
SLACK_BOT_TOKEN=
DISCORD_BOT_TOKEN=
WHATSAPP_TOKEN=

# ============================================================
# Base tooling + DB clients (lib/base-packages.sh)
# ============================================================
BASE_PACKAGES=
INSTALL_DB_CLIENTS=true
INSTALL_POSTGRES_CLIENT=true
INSTALL_CLICKHOUSE_CLIENT=true

# Headless browser (chromium via apt; fallback to Playwright bundled Chromium)
INSTALL_HEADLESS_BROWSER=true
