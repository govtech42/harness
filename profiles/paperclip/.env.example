# ============================================================
# Paperclip profile — Environment Variables
# Upstream: https://github.com/paperclipai/paperclip
# Runtime: Node 20+, pnpm 9.15+. API port 3100.
# Embedded PostgreSQL is auto-provisioned on first run.
# ============================================================
TIMEZONE=America/Sao_Paulo
SWAP_SIZE_GB=2

NODE_MAJOR=20
PNPM_VERSION=9.15.0

# true  = clone + pnpm build (recommended for repeatable dev).
# false = run `npx paperclipai onboard --yes` instead.
PAPERCLIP_USE_NPX=false

PAPERCLIP_DIR=/home/ubuntu/paperclip
PAPERCLIP_REPO=https://github.com/paperclipai/paperclip.git
PAPERCLIP_BRANCH=main

# Run API server as systemd unit.
PAPERCLIP_AS_SERVICE=false
PAPERCLIP_PORT=3100

# Telemetry off by default.
PAPERCLIP_TELEMETRY_DISABLED=1
DO_NOT_TRACK=1

# Provider keys not required for local stack (embedded DB), but commonly set.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ============================================================
# Base tooling + DB clients (lib/base-packages.sh)
# ============================================================
BASE_PACKAGES=
INSTALL_DB_CLIENTS=true
INSTALL_POSTGRES_CLIENT=true
INSTALL_CLICKHOUSE_CLIENT=true

# Headless browser (chromium via apt; fallback to Playwright bundled Chromium)
INSTALL_HEADLESS_BROWSER=true

# ============================================================
# Mission Control — self-hosted AI agent orchestration dashboard.
# Upstream: https://github.com/builderz-labs/mission-control
# Runtime: Node 22+, pnpm, SQLite. Default port 3000.
# ============================================================
INSTALL_MISSION_CONTROL=false
MC_DIR=/home/ubuntu/mission-control
MC_REPO=https://github.com/builderz-labs/mission-control.git
MC_BRANCH=main
MC_PORT=3000
MC_AS_SERVICE=false
MC_AUTH_USER=admin
# Leave MC_AUTH_PASS / MC_API_KEY empty to auto-generate on first install.
MC_AUTH_PASS=
MC_API_KEY=
MC_ALLOWED_HOSTS=
MC_DATA_DIR=/home/ubuntu/.mission-control
MC_CLAUDE_HOME=/home/ubuntu/.claude
MC_GATEWAY_OPTIONAL=true
OPENCLAW_CONFIG_PATH=/home/ubuntu/.openclaw/openclaw.json
OPENCLAW_STATE_DIR=/home/ubuntu/.openclaw
