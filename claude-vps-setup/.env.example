# ============================================================
# Claude Code VPS - Environment Variables
# Copy to .env and fill in your keys: cp .env.example .env
# ============================================================

# --- Claude Code Auth ---
# Option A: API key (console.anthropic.com). Leave empty to use OAuth via `claude login`.
ANTHROPIC_API_KEY=

# --- Context7 (Upstash) ---
# Optional. Free without key, higher rate limit with key from context7.com
CONTEXT7_API_KEY=

# --- Timezone ---
TIMEZONE=America/Sao_Paulo

# --- Swap (set to 0 to skip; recommended on 1GB VPS) ---
SWAP_SIZE_GB=2

# --- MCP install scope: user | local ---
# user = global for all projects (recommended on single-user VPS)
MCP_SCOPE=user

# ============================================================
# Toggle which MCP servers to install (true/false)
# ============================================================
INSTALL_CONTEXT7=true
INSTALL_LINEAR=true
INSTALL_SLACK=true
INSTALL_GITHUB=true
INSTALL_SUPABASE=true
INSTALL_SENTRY=false
INSTALL_NOTION=false
INSTALL_PLAYWRIGHT=false
INSTALL_FILESYSTEM=false

# Filesystem MCP: dirs to expose (space-separated, absolute paths)
FILESYSTEM_PATHS=/home/ubuntu/projects

# ============================================================
# Dream mode — periodic reflective consolidation of ~/.claude/memory/
# Invokes the `anthropic-skills:consolidate-memory` skill in headless mode.
# Install the skill once inside Claude: `/plugin install anthropic-skills`
# (fallback inline prompt runs if skill is absent).
# ============================================================
INSTALL_DREAM=false
# Cron expression (user crontab). Default: daily at 03:00 local time.
DREAM_SCHEDULE=0 3 * * *
# Optional: override the default prompt sent to `claude -p`.
DREAM_PROMPT=
